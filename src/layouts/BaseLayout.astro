---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { u, langPair } from '../lib/url';

interface Props {
  title: string;
  description?: string;
  lang?: 'ro' | 'en';
}

const {
  title,
  description = 'Platforme de date, software custom și consultanță în digitalizare pentru primării și companii B2B din România.',
  lang = 'ro',
} = Astro.props;

const site = (Astro.site?.toString() ?? 'https://thorn.ro').replace(/\/$/, '');
const pair = langPair(Astro.url.pathname);
const canonical = `${site}${u(lang === 'ro' ? pair.ro : pair.en)}`;

// Cloudflare Web Analytics: token injected at build time via CF_ANALYTICS_TOKEN.
// Absent (e.g. local dev or PR builds) -> snippet is simply not rendered.
const cfAnalyticsToken = import.meta.env.CF_ANALYTICS_TOKEN ?? '';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#243e2f" />
    <meta name="description" content={description} />

    <!-- Icons + canonical + language alternates -->
    <link rel="icon" type="image/svg+xml" href={u('/favicon.svg')} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ro" href={`${site}${u(pair.ro)}`} />
    <link rel="alternate" hreflang="en" href={`${site}${u(pair.en)}`} />
    <link rel="alternate" hreflang="x-default" href={`${site}${u(pair.ro)}`} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Thorn" />
    <meta property="og:locale" content={lang === 'ro' ? 'ro_RO' : 'en_GB'} />

    <!-- Preconnect to font CDN -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Inter + JetBrains Mono -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- Mobile drawer toggle script -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('mobile-nav-toggle');
        const drawer = document.getElementById('mobile-nav-drawer');
        const closeBtn = document.getElementById('mobile-nav-close');
        const body = document.body;

        if (!toggle || !drawer) return;

        const open = () => {
          drawer.classList.remove('opacity-0', 'pointer-events-none');
          drawer.classList.add('opacity-100');
          body.classList.add('scroll-lock');
          toggle.setAttribute('aria-expanded', 'true');
          // Focus first link inside drawer
          setTimeout(() => {
            const firstLink = drawer.querySelector('a');
            if (firstLink) firstLink.focus();
          }, 150);
        };

        const close = () => {
          drawer.classList.add('opacity-0', 'pointer-events-none');
          drawer.classList.remove('opacity-100');
          body.classList.remove('scroll-lock');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.focus();
        };

        toggle.addEventListener('click', () => {
          if (toggle.getAttribute('aria-expanded') === 'true') {
            close();
          } else {
            open();
          }
        });

        if (closeBtn) closeBtn.addEventListener('click', close);

        // Close on any link click inside drawer
        drawer.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', close);
        });

        // Escape to close
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
            close();
          }
        });
      });
    </script>

    {cfAnalyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}
      />
    )}
  </body>
</html>
