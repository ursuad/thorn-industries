---
import BaseLayout from '../layouts/BaseLayout.astro';
import { u } from '../lib/url';
---

<BaseLayout
  title="404 · Thorn Industries"
  description="Pagina căutată nu există."
  lang="ro"
>
  <section class="surface-light pt-12 md:pt-20 pb-16 md:pb-24">
    <div class="container-page">
      <div class="eyebrow text-forest-700 mb-8 md:mb-10">
        <span class="font-mono">404</span>
        <span class="mx-3 text-ink-300">·</span>
        Pagina nu există
      </div>
      <h1 class="font-sans font-medium text-display-1 text-ink-900 hang tracking-tight">
        Pagina căutată<br/>
        <span class="text-ink-400">nu există.</span>
      </h1>
      <p class="text-ink-600 text-body mt-8 max-w-xl leading-relaxed">
        Adresa s-a schimbat sau nu a existat niciodată.
        <span class="block mt-1">The page you are looking for does not exist.</span>
      </p>
      <div class="mt-10 flex flex-wrap gap-x-8 gap-y-3">
        <a href={u('/')} class="font-sans font-medium text-forest-800 hover:text-forest-600 transition-colors">
          &larr; Înapoi la prima pagină
        </a>
        <a href={u('/en/')} class="font-sans font-medium text-ink-500 hover:text-forest-600 transition-colors">
          English home &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
