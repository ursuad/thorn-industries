---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact · Thorn Industries"
  description="Get in touch with Thorn. Email or contact form, replies within a working day."
  lang="en"
>

  <!-- HERO -->
  <section class="surface-light pt-12 md:pt-20 pb-16 md:pb-24">
    <div class="container-page">
      <div class="grid md:grid-cols-12 gap-y-8 md:gap-x-10">
        <div class="md:col-span-9">
          <div class="eyebrow text-forest-700 mb-8 md:mb-10">
            <span class="font-mono">001</span>
            <span class="mx-3 text-ink-300">·</span>
            Contact
          </div>
          <h1 class="font-sans font-medium text-display-1 text-ink-900 hang tracking-tight">
            Tell us what<br/>
            <span class="text-ink-400">you're working on.</span>
          </h1>
        </div>

        <aside class="md:col-span-3 md:pt-32 md:border-l md:border-forest-100 md:pl-6">
          <div class="eyebrow text-ink-500 mb-3">Reply time</div>
          <div class="text-ink-900 text-body-sm mb-6 leading-relaxed">
            Within a working day,<br/>
            usually faster
          </div>

          <div class="eyebrow text-ink-500 mb-3">Routing</div>
          <div class="text-ink-900 text-body-sm leading-relaxed">
            Goes to one inbox<br/>
            we both read
          </div>
        </aside>
      </div>

      <div class="mt-12 md:mt-16 max-w-2xl">
        <p class="text-body-lg text-ink-700 leading-relaxed">
          The more concrete you are, the more useful our first reply will be. A two-paragraph description of the problem is plenty to get a real answer back.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact options + form -->
  <section class="surface-medium section">
    <div class="container-page">
      <div class="grid md:grid-cols-12 gap-10 md:gap-16">

        <!-- Direct channels -->
        <div class="md:col-span-5">
          <div class="eyebrow text-forest-700 mb-6">002 · Direct channels</div>

          <div class="space-y-10">
            <div>
              <div class="eyebrow text-ink-500 mb-3">General</div>
              <a href="mailto:contact@thorn.ro" class="font-sans font-semibold text-2xl text-ink-900 no-underline hover:text-forest-800 transition-colors tracking-tight block">
                contact@thorn.ro
              </a>
              <p class="text-body-sm text-ink-500 mt-2">Replies within a working day.</p>
            </div>

            <div class="pt-8 border-t border-forest-100">
              <div class="eyebrow text-ink-500 mb-3">Public-sector enquiries</div>
              <a href="mailto:ioana@thorn.ro" class="font-sans font-medium text-lg text-ink-900 no-underline hover:text-forest-800 transition-colors block">
                ioana@thorn.ro
              </a>
              <p class="text-body-sm text-ink-500 mt-2">
                Ioana Drăghici, Sales lead<br/>
                Direct line for primării conversations
              </p>
            </div>

            <div class="pt-8 border-t border-forest-100">
              <div class="eyebrow text-ink-500 mb-3">Technical & B2B</div>
              <a href="mailto:adrian@thorn.ro" class="font-sans font-medium text-lg text-ink-900 no-underline hover:text-forest-800 transition-colors block">
                adrian@thorn.ro
              </a>
              <p class="text-body-sm text-ink-500 mt-2">
                Adrian Ursu, Founder & Principal architect<br/>
                Direct line for technical scoping
              </p>
            </div>

            <div class="pt-8 border-t border-forest-100">
              <div class="eyebrow text-ink-500 mb-3">Registered office</div>
              <p class="text-ink-700 text-body-sm leading-relaxed">
                Tech Camp Pro SRL<br/>
                Str. Traian Vuia 95<br/>
                Cluj-Napoca, Romania
              </p>
            </div>
          </div>
        </div>

        <!-- Contact form -->
        <div class="md:col-span-7">
          <div class="eyebrow text-forest-700 mb-6">003 · Send a message</div>

          <form
            action="https://formspree.io/f/mzdqkjvw"
            method="POST"
            class="space-y-8"
          >
            <div>
              <label for="name" class="form-label">Your name</label>
              <input id="name" name="name" type="text" required class="form-input" />
            </div>

            <div>
              <label for="organisation" class="form-label">Organisation</label>
              <input id="organisation" name="organisation" type="text" class="form-input" />
            </div>

            <div>
              <label for="email" class="form-label">Email</label>
              <input id="email" name="email" type="email" required class="form-input" />
            </div>

            <div>
              <label for="topic" class="form-label">Topic</label>
              <select id="topic" name="topic" class="form-select">
                <option>Public-sector engagement</option>
                <option>B2B data or integration work</option>
                <option>Consultancy assessment</option>
                <option>General enquiry</option>
              </select>
            </div>

            <div>
              <label for="message" class="form-label">What's on your mind?</label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                placeholder="A couple of paragraphs about the problem, what you've tried, and what good would look like."
                class="form-textarea"
              ></textarea>
            </div>

            <div class="pt-4">
              <button type="submit" class="btn-primary w-full sm:w-auto justify-center">
                Send message
                <svg class="btn-arrow" width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                  <path d="M0 5h12M8 1l4 4-4 4" stroke="currentColor" stroke-width="1.5" fill="none"/>
                </svg>
              </button>
              <p class="text-body-sm text-ink-500 mt-6 max-w-md">
                We reply directly, not through automated funnels. Your message goes to one inbox we both read.
              </p>
            </div>
          </form>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
