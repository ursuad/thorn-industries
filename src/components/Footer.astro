---
import { u } from '../lib/url';

interface Props {
  lang?: 'ro' | 'en';
}
const { lang = 'ro' } = Astro.props;

const text = {
  ro: {
    tagline: 'Inginerie de date și de software pentru administrația publică și pentru companii B2B din România.',
    contact: 'Contact',
    nav: 'Navigare',
    company: 'Companie',
    address: 'Str. Traian Vuia 95, Cluj-Napoca',
    operatedBy: 'Operat de Tech Camp Pro SRL',
    cui: 'CUI RO__________',
    seap: 'Înregistrați SEAP',
    rights: 'Toate drepturile rezervate.',
    links: [
      { href: '/servicii', label: 'Servicii' },
      { href: '/primarii', label: 'Primării' },
      { href: '/companii', label: 'Companii' },
      { href: '/cum-lucram', label: 'Cum lucrăm' },
      { href: '/despre', label: 'Despre' },
      { href: '/contact', label: 'Contact' },
    ],
  },
  en: {
    tagline: 'Data and software engineering for Romanian public administration and B2B companies.',
    contact: 'Contact',
    nav: 'Navigation',
    company: 'Company',
    address: 'Str. Traian Vuia 95, Cluj-Napoca',
    operatedBy: 'Operated by Tech Camp Pro SRL',
    cui: 'VAT RO__________',
    seap: 'SEAP registered',
    rights: 'All rights reserved.',
    links: [
      { href: '/en/services', label: 'Services' },
      { href: '/en/public-sector', label: 'Public sector' },
      { href: '/en/companies', label: 'Companies' },
      { href: '/en/how-we-work', label: 'How we work' },
      { href: '/en/about', label: 'About' },
      { href: '/en/contact', label: 'Contact' },
    ],
  },
};

const t = text[lang];
const year = new Date().getFullYear();
---

<footer class="surface-dark mt-section">
  <div class="container-page py-16 md:py-20">

    <!-- Top: oversized wordmark + tagline -->
    <div class="grid md:grid-cols-12 gap-10 pb-12 border-b border-forest-700">
      <div class="md:col-span-7">
        <div class="font-sans text-display-3 text-cream-50 leading-[1.05] mb-6 hang tracking-tight">
          <span class="font-semibold">Thorn</span><span class="font-normal text-cream-100/70"> Industries.</span>
        </div>
        <p class="text-cream-100/80 text-body-lg leading-relaxed max-w-md">
          {t.tagline}
        </p>
      </div>
      <div class="md:col-span-5 md:pl-8 md:border-l md:border-forest-700">
        <div class="eyebrow text-forest-300 mb-4">{t.contact}</div>
        <a
          href="mailto:contact@thorn.ro"
          class="text-cream-50 text-body-lg no-underline hover:text-forest-300 transition-colors block mb-1"
        >
          contact@thorn.ro
        </a>
        <div class="text-cream-100/60 text-body-sm leading-relaxed">
          {t.address}<br />
          {t.operatedBy}
        </div>
      </div>
    </div>

    <!-- Middle: nav + company columns -->
    <div class="grid md:grid-cols-12 gap-10 py-12 border-b border-forest-700">
      <div class="md:col-span-6">
        <div class="eyebrow text-forest-300 mb-5">{t.nav}</div>
        <ul class="grid grid-cols-2 gap-y-2 gap-x-8">
          {t.links.map((l) => (
            <li>
              <a
                href={u(l.href)}
                class="text-cream-100 text-body-sm no-underline hover:text-cream-50 transition-colors"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div class="md:col-span-6">
        <div class="eyebrow text-forest-300 mb-5">{t.company}</div>
        <dl class="grid grid-cols-2 gap-y-2 gap-x-8 text-body-sm">
          <dt class="text-cream-100/60">{lang === 'ro' ? 'CUI' : 'VAT'}</dt>
          <dd class="font-mono tabular text-cream-100">{t.cui.replace(/^(VAT |CUI )/, '')}</dd>
          <dt class="text-cream-100/60">SEAP</dt>
          <dd class="text-cream-100">{t.seap}</dd>
          <dt class="text-cream-100/60">{lang === 'ro' ? 'GDPR' : 'GDPR'}</dt>
          <dd class="text-cream-100">{lang === 'ro' ? 'Conform' : 'Compliant'}</dd>
        </dl>
      </div>
    </div>

    <!-- Bottom: tiny print -->
    <div class="pt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-3 text-body-sm text-cream-100/50">
      <div>© {year} Thorn Industries. {t.rights}</div>
      <div class="font-mono text-[11px] tracking-[0.15em] uppercase">
        v0.3
      </div>
    </div>
  </div>
</footer>
