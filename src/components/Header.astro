---
import { u, altPath } from '../lib/url';

interface Props {
  lang?: 'ro' | 'en';
}
const { lang = 'ro' } = Astro.props;

const nav = {
  ro: [
    { href: '/servicii', label: 'Servicii' },
    { href: '/primarii', label: 'Primării' },
    { href: '/companii', label: 'Companii' },
    { href: '/cum-lucram', label: 'Cum lucrăm' },
    { href: '/despre', label: 'Despre' },
  ],
  en: [
    { href: '/en/services', label: 'Services' },
    { href: '/en/public-sector', label: 'Public sector' },
    { href: '/en/companies', label: 'Companies' },
    { href: '/en/how-we-work', label: 'How we work' },
    { href: '/en/about', label: 'About' },
  ],
};

const contactLabel = lang === 'ro' ? 'Contact' : 'Contact';
const items = nav[lang];
const altHref = altPath(Astro.url.pathname); // same page in the other language
const altLabel = lang === 'ro' ? 'EN' : 'RO';
const homeHref = lang === 'ro' ? '/' : '/en/';
const contactHref = lang === 'ro' ? '/contact' : '/en/contact';
const menuOpenLabel = lang === 'ro' ? 'Meniu' : 'Menu';
const menuCloseLabel = lang === 'ro' ? 'Închide' : 'Close';
---

<header class="sticky top-0 z-40 border-b border-forest-100 bg-cream-50/85 backdrop-blur-md">
  <div class="container-page flex items-center justify-between py-4 md:py-5">
    <!-- Wordmark -->
    <a href={u(homeHref)} class="no-underline group flex items-baseline gap-2 -ml-1 px-1 py-1">
      <span class="font-sans text-xl md:text-[22px] font-semibold tracking-tight text-forest-900 leading-none">
        Thorn
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label={lang === 'ro' ? 'Navigare principală' : 'Main navigation'}>
      {items.map((item) => (
        <a
          href={u(item.href)}
          class="text-[14px] text-ink-700 no-underline hover:text-forest-900 transition-colors"
        >
          {item.label}
        </a>
      ))}
      <a
        href={u(contactHref)}
        class="text-[14px] text-ink-700 no-underline hover:text-forest-900 transition-colors"
      >
        {contactLabel}
      </a>
      <span class="text-ink-300" aria-hidden="true">·</span>
      <a
        href={u(altHref)}
        class="font-mono text-[11px] tracking-[0.15em] text-ink-500 no-underline hover:text-forest-800 transition-colors"
        aria-label={`Switch to ${altLabel}`}
      >
        {altLabel}
      </a>
    </nav>

    <!-- Mobile toggle -->
    <button
      id="mobile-nav-toggle"
      type="button"
      class="md:hidden inline-flex items-center gap-2 -mr-2 px-3 py-2 text-ink-800 hover:text-forest-900"
      aria-expanded="false"
      aria-controls="mobile-nav-drawer"
      aria-label={menuOpenLabel}
    >
      <span class="text-eyebrow">{menuOpenLabel}</span>
      <svg width="20" height="14" viewBox="0 0 20 14" fill="none" aria-hidden="true">
        <line x1="0" y1="2" x2="20" y2="2" stroke="currentColor" stroke-width="1.5" />
        <line x1="0" y1="12" x2="20" y2="12" stroke="currentColor" stroke-width="1.5" />
      </svg>
    </button>
  </div>
</header>

<!-- Mobile drawer overlay (always rendered for transitions) -->
<div
  id="mobile-nav-drawer"
  class="fixed inset-0 z-50 bg-forest-900 text-cream-100 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
  role="dialog"
  aria-modal="true"
  aria-label={lang === 'ro' ? 'Navigare' : 'Navigation'}
>
  <div class="container-page flex items-center justify-between py-4">
    <a
      href={u(homeHref)}
      class="no-underline flex items-baseline gap-2 -ml-1 px-1 py-1 text-cream-50"
    >
      <span class="font-sans text-xl font-semibold tracking-tight leading-none">Thorn</span>
    </a>
    <button
      id="mobile-nav-close"
      type="button"
      class="inline-flex items-center gap-2 -mr-2 px-3 py-2 text-cream-50"
      aria-label={menuCloseLabel}
    >
      <span class="text-eyebrow">{menuCloseLabel}</span>
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <line x1="2" y1="2" x2="16" y2="16" stroke="currentColor" stroke-width="1.5" />
        <line x1="16" y1="2" x2="2" y2="16" stroke="currentColor" stroke-width="1.5" />
      </svg>
    </button>
  </div>

  <nav
    class="container-page pt-12 pb-16"
    aria-label={lang === 'ro' ? 'Navigare mobilă' : 'Mobile navigation'}
  >
    <ul class="space-y-1">
      {items.map((item, i) => (
        <li>
          <a
            href={u(item.href)}
            class="font-sans text-3xl md:text-4xl font-medium tracking-tight text-cream-50 no-underline flex items-baseline gap-4 py-3 hover:text-forest-300 transition-colors"
          >
            <span class="font-mono text-[12px] tracking-[0.15em] text-forest-400 w-8">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span>{item.label}</span>
          </a>
        </li>
      ))}
      <li>
        <a
          href={u(contactHref)}
          class="font-sans text-3xl md:text-4xl font-medium tracking-tight text-cream-50 no-underline flex items-baseline gap-4 py-3 hover:text-forest-300 transition-colors"
        >
          <span class="font-mono text-[12px] tracking-[0.15em] text-forest-400 w-8">
            {String(items.length + 1).padStart(2, '0')}
          </span>
          <span>{contactLabel}</span>
        </a>
      </li>
    </ul>

    <div class="mt-16 pt-8 border-t border-forest-700 flex items-center justify-between">
      <a
        href="mailto:contact@thorn.ro"
        class="text-cream-50 no-underline text-base"
      >
        contact@thorn.ro
      </a>
      <a
        href={u(altHref)}
        class="font-mono text-[12px] tracking-[0.18em] text-forest-300 no-underline border border-forest-700 rounded-full px-4 py-2 hover:border-forest-400 hover:text-cream-50 transition-colors"
      >
        {altLabel}
      </a>
    </div>
  </nav>
</div>
